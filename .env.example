# Copy to .env (gitignored). make-image.sh and run-qemu.sh source this file
# and will fail if it's missing, so at minimum create an empty .env.

# Extra flags passed to qemu-system-x86_64. For headless/scriptable runs
# (e.g. reading kernel debugcon output without a display), try:
# TESTOS_QEMU_FLAGS=-debugcon stdio -display none

# OVMF firmware paths. Default to the vendored copy under third_party/ovmf so a
# clean checkout boots with no network. Override to use a different firmware
# (e.g. a distro OVMF under /usr/share/OVMF).
# TESTOS_QEMU_EFI_CODE=third_party/ovmf/x64/code.fd
# TESTOS_QEMU_EFI_VARS=third_party/ovmf/x64/vars.fd
