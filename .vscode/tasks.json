{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "command": "./make-image.sh",
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "Build UEFI image"
        },
        {
            "type": "cargo",
            "command": "kclippy",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "label": "Clippy (kernel)"
        },
        {
            "type": "cargo",
            "command": "kcheck",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "label": "Check (kernel)"
        },
        {
            "label": "Debug in QEMU",
            "type": "shell",
            "command": "./run-qemu.sh -s -S",
            "problemMatcher": [],
            "dependsOn": ["Build UEFI image"]
        },
        {
            "label": "Run in QEMU",
            "type": "shell",
            "command": "./run-qemu.sh -s",
            "problemMatcher": [],
            "dependsOn": ["Build UEFI image"]
        }
    ]
}
